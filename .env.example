# Copy to `.env` and fill in. Source before running scripts: `source .env`.
#
# Datasets, calibration, and training outputs land inside the repo under
# `data/` and `outputs/` (both gitignored). Scripts in `scripts/` set
# `HF_LEROBOT_HOME` automatically — only the variables below need values.

# USB serial ports for the SO-ARM101 pair. Discover with `uv run lerobot-find-port`.
ARM_FARM_FOLLOWER_PORT=/dev/tty.usbmodem58760431541
ARM_FARM_LEADER_PORT=/dev/tty.usbmodem58760431542

# Camera device indices. Discover with `uv run lerobot-find-cameras`.
ARM_FARM_WRIST_CAM=0
ARM_FARM_FRONT_CAM=1

# Logical IDs — calibration files are stored at
# `data/calibration/{robots,teleoperators}/<robot_type>/<id>.json`
# and reused on every subsequent run.
ARM_FARM_FOLLOWER_ID=follower_01
ARM_FARM_LEADER_ID=leader_01

# Namespace prefix for local dataset directory names. Datasets live at
# `data/<HF_USER>/<dataset_name>` and are never pushed.
HF_USER=arm_farm

# WandB for training metrics.
WANDB_PROJECT=arm_farm
# WANDB_ENTITY=

# Override to point lerobot artifacts somewhere other than `<repo>/data`
# (e.g. a shared dataset cache across projects). Leave unset for the default.
# HF_LEROBOT_HOME=/absolute/path
